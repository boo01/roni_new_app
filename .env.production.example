# Template for the server's /srv/roni5/.env (the real file is NOT committed).
# Copy to .env on the server and fill in the secrets. Both Laravel AND
# docker-compose.prod.yml read this file.

APP_NAME=Roni
APP_ENV=production
APP_KEY=            # generate on server: docker compose exec app php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://152.53.14.199:8000

APP_LOCALE=ka
APP_FALLBACK_LOCALE=ka
APP_FAKER_LOCALE=ka_GE

APP_MAINTENANCE_DRIVER=file
LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (MySQL container) -----------------------------------------
# DB_HOST is the compose service name; the app talks to it on the internal
# 3306. From your PC connect to 152.53.14.199:3311 with the same credentials.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=roni5
DB_USERNAME=roni5
DB_PASSWORD=CHANGE_ME_STRONG
# Used only by the mysql container (root password); keep it secret.
DB_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT

# --- Drivers (all DB-backed, no Redis) ----------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Mail (still log until SMTP is configured) --------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@roni5.ge"
MAIL_FROM_NAME="${APP_NAME}"
